{
    "interface_version": 2,
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py",
            "-dev"
        ]
    },
    "name": "MDNA",
    "title": "二重螺旋小助手 Oᴗoಣ 旅途愉快~ | 版本号:1.1.13 | 如果出现了bug,请在群里或github的issue中上传日志",
    "description": "使用前请将模拟器分辨率设置为16：9哦~~",
    "icon": "./resource/image/logo.ico",
    "contact": "QQ群:1002051753",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MDNA!",
    "github": "https://github.com/BQOvO/MDNA",
    "version": "1.1.13",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        }
    ],
    "resource": [
        {
            "name": "模拟器",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [
        {
            "name":"检查分辨率·16：9",
            "entry":"检查设置-启动节点",
            "default_check": true,
            "description":"该任务可以帮你检查分辨率是否正确喵~\n\n【其他设置喵~】：\n\n1.该任务可在模拟器启动后的任何界面开始\n\n2.请将按键布局设置为默认布局2，并且不要自定义按键布局\n\n3.在画面设置中将品质预设改为极低\n\n4.将人物密度改为极高（可有效防止卡怪和提高挂机效率）"
        }
    ]
}
