{
    "interface_version": 2,
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py",
            "-dev"
        ]
    },
    "name": "MDNA",
    "title": "二重螺旋小助手 Oᴗoಣ 旅途愉快~ | 版本号:1.1.13 | 如果出现了bug,请在群里或github的issue中上传日志",
    "description": "使用前请将模拟器分辨率设置为16：9哦~~",
    "icon": "./resource/image/logo.ico",
    "contact": "QQ群:1002051753",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MDNA!",
    "github": "https://github.com/BQOvO/MDNA",
    "version": "1.1.13",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "模拟器",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        }
    ],
    "resource": [
        {
            "name": "模拟器",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [
        {
            "name": "检查分辨率·16：9",
            "entry": "检查设置-启动节点",
            "default_check": true,
            "description": "该任务可以帮你检查分辨率是否正确喵~\n\n【其他设置喵~】：\n\n1.该任务可在模拟器启动后的任何界面开始\n\n2.请将按键布局设置为默认布局2，并且不要自定义按键布局\n\n3.在画面设置中将品质预设改为极低\n\n4.将人物密度改为极高（可有效防止卡怪和提高挂机效率）"
        },
        {
            "name": "魔之锲·驱离",
            "entry": "魔之锲·驱离-启动节点",
            "default_check": false,
            "description": "嘻嘻~小菲比帮你刷魔之锲喵",
            "option": [
                "魔之锲·驱离-等级选择",
                "加成书选择",
                "是否开局复位",
                "自定义战斗配置"
            ]
        }
    ],
    "option": {
        "魔之锲·驱离-等级选择": {
            "type": "select",
            "label": "挑战等级",
            "default_case": "Lv.40",
            "cases": [
                {
                    "name": "Lv.40",
                    "pipeline_override": {
                        "魔之锲·驱离-启动节点": {
                            "next": "魔之锲·驱离-等级选择-40级"
                        }
                    }
                },
                {
                    "name": "Lv.60",
                    "pipeline_override": {
                        "魔之锲·驱离-启动节点": {
                            "next": "魔之锲·驱离-等级选择-60级"
                        }
                    }
                },
                {
                    "name": "Lv.80",
                    "pipeline_override": {
                        "魔之锲·驱离-启动节点": {
                            "next": "魔之锲·驱离-等级选择-80级"
                        }
                    }
                },
                {
                    "name": "Lv.100",
                    "pipeline_override": {
                        "魔之锲·驱离-启动节点": {
                            "next": "魔之锲·驱离-等级选择-100级"
                        }
                    }
                }
            ]
        },
        "加成书选择": {
            "type": "select",
            "label": "加成书选择",
            "default_case": "不用书",
            "cases": [
                {
                    "name": "不用书",
                    "pipeline_override": {
                        "魔之锲·驱离-开始挑战": {
                            "next": "魔之锲·驱离-不选书"
                        },
                        "魔之锲·驱离-再次进行": {
                            "next": "魔之锲·驱离-不选书"
                        }
                    }
                },
                {
                    "name": "绿书",
                    "icon": "./resource/image/加成书/绿书.png",
                    "pipeline_override": {
                        "魔之锲·驱离-开始挑战": {
                            "next": "魔之锲·驱离-选绿书"
                        },
                        "魔之锲·驱离-再次进行": {
                            "next": "魔之锲·驱离-选绿书"
                        }
                    }
                },
                {
                    "name": "蓝书",
                    "icon": "./resource/image/加成书/蓝书.png",
                    "pipeline_override": {
                        "魔之锲·驱离-开始挑战": {
                            "next": "魔之锲·驱离-选蓝书"
                        },
                        "魔之锲·驱离-再次进行": {
                            "next": "魔之锲·驱离-选蓝书"
                        }
                    }
                },
                {
                    "name": "紫书",
                    "icon": "./resource/image/加成书/紫书.png",
                    "pipeline_override": {
                        "魔之锲·驱离-开始挑战": {
                            "next": "魔之锲·驱离-选紫书"
                        },
                        "魔之锲·驱离-再次进行": {
                            "next": "魔之锲·驱离-选紫书"
                        }
                    }
                },
                {
                    "name": "金书",
                    "icon": "./resource/image/加成书/金书.png",
                    "pipeline_override": {
                        "魔之锲·驱离-开始挑战": {
                            "next": "魔之锲·驱离-选金书"
                        },
                        "魔之锲·驱离-再次进行": {
                            "next": "魔之锲·驱离-选金书"
                        }
                    }
                }
            ]
        },
        "是否开局复位": {
            "type": "switch",
            "label": "是否开局复位",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "魔之锲·驱离-检测是否在战斗中": {
                            "next": "魔之锲·驱离-复位-点击退出门"
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "魔之锲·驱离-检测是否在战斗中": {
                            "next": "魔之锲·驱离-水母e技能"
                        }
                    }
                }
            ]
        },
        "自定义战斗配置": {
            "type": "input",
            "description": "1秒 = 1000ms",
            "inputs":[
                {
                    "name": "水母e技能间隔时间(ms)",
                    "description": "1秒=1000ms",
                    "default": "3000",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "魔之锲·驱离-战斗挂机延迟": {
                    "post_delay": "{水母e技能间隔时间(ms)}"
                }
            }
        }
    }
}